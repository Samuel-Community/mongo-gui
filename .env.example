# MongoDB connection string. Use a dedicated MongoDB user with minimum privileges.
MONGODB_URI=mongodb://localhost:27017

# Required. Use a long random value.
JWT_SECRET=change_me_with_a_long_random_secret_at_least_32_chars

# full = allow writes, readonly = block imports/update/delete/drop/index/validation changes.
MONGO_GUI_MODE=full

# Safety limits
MONGO_QUERY_MAX_TIME_MS=5000
MAX_IMPORT_BODY_BYTES=20971520
MAX_QUERY_STRING_LENGTH=20000
MAX_AGGREGATION_STAGES=25
MAX_SCHEMA_SAMPLE_SIZE=1000
